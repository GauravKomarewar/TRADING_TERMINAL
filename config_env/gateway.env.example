# ============================================================
# SHOONYA PLATFORM — GATEWAY CONFIG
# ============================================================
# Copy to: config_env/gateway.env
# Run:     python gateway_main.py --env config_env/gateway.env
#
# ⚠️ SECURITY WARNING: Binding to 0.0.0.0 exposes the gateway on ALL network
# interfaces publicly. In production, only use 0.0.0.0 when the service is
# protected by a firewall, a secured reverse proxy (nginx/Caddy), or TLS with
# strong auth. For development or single-host use, bind to 127.0.0.1 instead.
# ============================================================

# Gateway bind settings
GATEWAY_HOST=127.0.0.1            # ⚠️ Use 127.0.0.1 unless behind a proxy; see warning above
GATEWAY_PORT=7000                 # Single public-facing port for all clients

# JSON file listing client aliases and their internal ports
GATEWAY_ROUTES_FILE=config_env/client_routes.json

# ============================================================
# 🔐 TLS SETTINGS (OPTIONAL — enable when not behind a TLS-terminating proxy)
# ============================================================
GATEWAY_TLS_ENABLED=false                 # Set to true to enable TLS on the gateway itself
# GATEWAY_CERT_PATH=/etc/ssl/certs/gateway.crt
# GATEWAY_KEY_PATH=/etc/ssl/private/gateway.key
# GATEWAY_TLS_PROTOCOLS=TLSv1.2,TLSv1.3  # Allowed TLS protocol versions
# GATEWAY_TLS_CIPHERS=HIGH:!aNULL:!MD5    # OpenSSL cipher string

# ============================================================
# 🛡️ PROXY / AUTH SETTINGS
# ============================================================
GATEWAY_BEHIND_PROXY=false        # Set to true when behind nginx/Caddy/ALB (trust X-Forwarded-For)
GATEWAY_AUTH_ENABLED=false        # Enable gateway-level auth (requires a provider below)
# GATEWAY_AUTH_JWT_SECRET=CHANGE_THIS_JWT_SECRET_REPLACE_WITH_RANDOM_HEX
# GATEWAY_AUTH_PROVIDER=jwt        # Options: jwt | header_token
