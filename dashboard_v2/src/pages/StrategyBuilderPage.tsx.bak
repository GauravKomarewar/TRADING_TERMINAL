import { useState } from 'react'
import { Cpu, Loader2, RefreshCw, Save, ShieldCheck, Trash2 } from 'lucide-react'
import { useStrategies } from '../hooks'
import { api } from '../lib/api'
import { cn } from '../lib/utils'
import { useUIStore } from '../stores'
import type { StrategyValidationResult } from '../types'

type RawConfig = Record<string, unknown>

const EMPTY_TEMPLATE = {
  name: '',
  identity: {
    underlying: 'NIFTY',
    exchange: 'NFO',
  },
  timing: {
    entry_window_start: '09:20',
    entry_window_end: '14:30',
    eod_exit_time: '15:15',
  },
  entry: {
    legs: [],
  },
}

export default function StrategyBuilderPage() {
  const { data, isLoading, refetch } = useStrategies()
  const { addToast } = useUIStore()
  const strategies = data?.strategies || []

  const [selectedName, setSelectedName] = useState('')
  const [editor, setEditor] = useState(JSON.stringify(EMPTY_TEMPLATE, null, 2))
  const [dirty, setDirty] = useState(false)
  const [busyAction, setBusyAction] = useState('')
  const [validation, setValidation] = useState<StrategyValidationResult | null>(null)
  const [cloneName, setCloneName] = useState('')
  const [renameName, setRenameName] = useState('')

  const parseEditor = (): RawConfig | null => {
    try {
      return JSON.parse(editor) as RawConfig
    } catch {
      return null
    }
  }

  async function run(action: string, fn: () => Promise<void>) {
    setBusyAction(action)
    try {
      await fn()
    } finally {
      setBusyAction('')
    }
  }

  const loadConfig = async (strategyName: string) => {
    await run(`load-${strategyName}`, async () => {
      const config = await api.getRawStrategyConfig(strategyName)
      setSelectedName(strategyName)
      setEditor(JSON.stringify(config, null, 2))
      setDirty(false)
      setValidation(null)
      setCloneName(`${strategyName}_COPY`)
      setRenameName(strategyName)
    })
  }

  const validateCurrent = async () => {
    const payload = parseEditor()
    if (!payload) {
      addToast('error', 'Invalid JSON in editor')
      return
    }

    await run('validate', async () => {
      const result = await api.validateStrategyConfig(payload)
      setValidation(result)
      if (result.valid) addToast('success', 'Validation passed')
      else addToast('warning', `Validation failed (${(result.errors || []).length} errors)`) 
    })
  }

  const saveCurrent = async () => {
    const payload = parseEditor()
    if (!payload) {
      addToast('error', 'Invalid JSON in editor')
      return
    }

    const name = String(payload.name || selectedName || '').trim()
    if (!name) {
      addToast('error', 'Strategy name is required in payload.name')
      return
    }

    await run('save', async () => {
      if (selectedName) await api.updateStrategyConfig(selectedName, payload)
      else await api.createStrategyConfig(payload)

      await refetch()
      setSelectedName(name)
      setDirty(false)
      addToast('success', `${selectedName ? 'Updated' : 'Created'} ${name}`)
      await loadConfig(name)
    })
  }

  const cloneCurrent = async () => {
    if (!selectedName || !cloneName.trim()) return
    await run('clone', async () => {
      await api.cloneStrategyConfig(selectedName, cloneName.trim())
      await refetch()
      addToast('success', `Cloned ${selectedName} → ${cloneName.trim()}`)
    })
  }

  const renameCurrent = async () => {
    if (!selectedName || !renameName.trim() || renameName.trim() === selectedName) return
    await run('rename', async () => {
      await api.renameStrategyConfig(selectedName, renameName.trim())
      await refetch()
      addToast('success', `Renamed ${selectedName} → ${renameName.trim()}`)
      await loadConfig(renameName.trim())
    })
  }

  const deleteCurrent = async () => {
    if (!selectedName) return
    if (!window.confirm(`Delete strategy '${selectedName}'?`)) return

    await run('delete', async () => {
      await api.deleteStrategyConfig(selectedName)
      await refetch()
      setSelectedName('')
      setEditor(JSON.stringify(EMPTY_TEMPLATE, null, 2))
      setDirty(false)
      setValidation(null)
      addToast('success', 'Strategy deleted')
    })
  }

  const createNew = () => {
    setSelectedName('')
    setEditor(JSON.stringify(EMPTY_TEMPLATE, null, 2))
    setDirty(false)
    setValidation(null)
  }

  return (
    <div className="space-y-4 animate-fade-in">
      <div className="glass rounded-xl px-4 py-3 flex items-center justify-between gap-3">
        <div className="flex items-center gap-2">
          <Cpu className="w-5 h-5 text-primary" />
          <div>
            <h1 className="text-sm font-semibold text-text-bright">Strategy Studio</h1>
            <p className="text-[11px] text-text-muted">Full config editor with validation and safe CRUD</p>
          </div>
        </div>

        <button
          onClick={() => refetch()}
          className="p-1.5 rounded-lg hover:bg-white/5 transition-colors"
          title="Refresh"
        >
          <RefreshCw className="w-4 h-4 text-text-secondary" />
        </button>
      </div>

      <div className="grid grid-cols-1 xl:grid-cols-[320px_1fr] gap-4">
        <div className="glass rounded-xl p-3 space-y-2 max-h-[calc(100vh-220px)] overflow-auto">
          <button
            onClick={createNew}
            className="w-full px-3 py-2 rounded-lg border border-primary/40 text-primary text-[12px] font-semibold"
          >
            + New Strategy
          </button>

          {isLoading ? (
            <div className="py-12 flex justify-center">
              <Loader2 className="w-5 h-5 animate-spin text-primary" />
            </div>
          ) : strategies.length === 0 ? (
            <div className="text-[12px] text-center text-text-muted py-8">No strategies found</div>
          ) : strategies.map((strategy) => (
            <button
              key={strategy.name}
              onClick={() => loadConfig(strategy.name)}
              className={cn(
                'w-full p-3 rounded-lg border text-left transition-colors',
                selectedName === strategy.name
                  ? 'border-primary/40 bg-primary/10'
                  : 'border-border hover:border-border-hover bg-bg-surface/30',
              )}
            >
              <div className="flex items-center gap-1.5 mb-1">
                <span className={cn('badge', strategy.mode === 'LIVE' ? 'badge-live' : 'badge-mock')}>
                  {strategy.mode}
                </span>
                <span className={cn(
                  'badge',
                  strategy.status === 'RUNNING'
                    ? 'badge-safe'
                    : strategy.status === 'PAUSED'
                      ? 'badge-warning'
                      : 'badge-neutral',
                )}>
                  {strategy.status}
                </span>
              </div>
              <div className="text-[12px] font-semibold text-text-bright truncate">{strategy.display_name || strategy.name}</div>
              <div className="text-[10px] text-text-muted font-mono truncate">{strategy.name}</div>
            </button>
          ))}
        </div>

        <div className="space-y-3">
          <div className="glass rounded-xl p-3 flex flex-wrap gap-2 items-center">
            <button
              onClick={validateCurrent}
              disabled={busyAction === 'validate' || busyAction === 'save'}
              className="px-3 py-1.5 rounded-md border border-border text-[11px] font-semibold text-text-secondary disabled:opacity-50"
            >
              {busyAction === 'validate' ? 'Validating...' : 'Validate'}
            </button>
            <button
              onClick={saveCurrent}
              disabled={busyAction === 'save'}
              className="px-3 py-1.5 rounded-md bg-primary text-bg-base text-[11px] font-semibold disabled:opacity-50 inline-flex items-center gap-1"
            >
              <Save className="w-3.5 h-3.5" /> {busyAction === 'save' ? 'Saving...' : selectedName ? 'Update' : 'Create'}
            </button>

            <div className="h-5 w-px bg-border" />

            <input
              value={renameName}
              onChange={(e) => setRenameName(e.target.value)}
              placeholder="Rename strategy"
              className="h-8 px-2.5 rounded-md bg-bg-input border border-border text-[11px] min-w-[180px]"
            />
            <button
              onClick={renameCurrent}
              disabled={!selectedName || !renameName.trim() || busyAction === 'rename'}
              className="px-3 py-1.5 rounded-md border border-border text-[11px] font-semibold text-text-secondary disabled:opacity-50"
            >
              {busyAction === 'rename' ? 'Renaming...' : 'Rename'}
            </button>

            <input
              value={cloneName}
              onChange={(e) => setCloneName(e.target.value)}
              placeholder="Clone as"
              className="h-8 px-2.5 rounded-md bg-bg-input border border-border text-[11px] min-w-[180px]"
            />
            <button
              onClick={cloneCurrent}
              disabled={!selectedName || !cloneName.trim() || busyAction === 'clone'}
              className="px-3 py-1.5 rounded-md border border-border text-[11px] font-semibold text-text-secondary disabled:opacity-50"
            >
              {busyAction === 'clone' ? 'Cloning...' : 'Clone'}
            </button>

            <button
              onClick={deleteCurrent}
              disabled={!selectedName || busyAction === 'delete'}
              className="ml-auto px-3 py-1.5 rounded-md border border-loss/40 text-loss text-[11px] font-semibold disabled:opacity-50 inline-flex items-center gap-1"
            >
              <Trash2 className="w-3.5 h-3.5" /> {busyAction === 'delete' ? 'Deleting...' : 'Delete'}
            </button>
          </div>

          <div className="glass rounded-xl p-3">
            <textarea
              value={editor}
              onChange={(e) => {
                setEditor(e.target.value)
                setDirty(true)
              }}
              spellCheck={false}
              className="w-full min-h-[500px] max-h-[68vh] bg-bg-base border border-border rounded-lg p-3 text-[11px] font-mono text-text-secondary resize-y"
            />
            <div className="mt-2 flex items-center justify-between text-[10px] text-text-muted">
              <span>{selectedName || 'New strategy draft'}</span>
              <span>{dirty ? 'Unsaved changes' : 'Synced'}</span>
            </div>
          </div>

          <div className={cn(
            'glass rounded-xl p-3 border',
            validation
              ? validation.valid
                ? 'border-profit/30 bg-profit/5'
                : 'border-loss/30 bg-loss/5'
              : 'border-border',
          )}>
            <div className="flex items-center gap-2 mb-2">
              <ShieldCheck className={cn('w-4 h-4', validation?.valid ? 'text-profit' : 'text-text-muted')} />
              <span className="text-[12px] font-semibold text-text-bright">Validation</span>
              {validation ? (
                <span className={cn('badge', validation.valid ? 'badge-safe' : 'badge-danger')}>
                  {validation.valid ? 'Valid' : 'Invalid'}
                </span>
              ) : (
                <span className="badge badge-neutral">Not run</span>
              )}
            </div>

            {validation ? (
              <div className="space-y-1 text-[11px]">
                {(validation.errors || []).slice(0, 8).map((err) => (
                  <div key={`e-${err}`} className="text-loss">• {err}</div>
                ))}
                {(validation.warnings || []).slice(0, 8).map((warning) => (
                  <div key={`w-${warning}`} className="text-warning">• {warning}</div>
                ))}
                {!(validation.errors || []).length && !(validation.warnings || []).length ? (
                  <div className="text-profit">No issues reported.</div>
                ) : null}
              </div>
            ) : (
              <p className="text-[11px] text-text-muted">Run validation before saving to ensure runtime schema compatibility.</p>
            )}
          </div>
        </div>
      </div>
    </div>
  )
}
