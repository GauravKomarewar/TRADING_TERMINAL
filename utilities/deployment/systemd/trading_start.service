[Unit]
Description=Trading Platform Start Service
After=network.target

[Service]
Type=oneshot
User=root
WorkingDirectory=/home/ubuntu/shoonya_platform
ExecStart=/bin/bash -c "systemctl start gateway.service && systemctl start master.service && systemctl start trading.service"
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
