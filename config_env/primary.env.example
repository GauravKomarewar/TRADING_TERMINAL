# 🔴 === Shoonya credentials (REQUIRED) ===
USER_NAME=YOUR_USER_NAME # 🔒 Shoonya user name
USER_ID=YOUR_USER_ID # 🔒 Shoonya client id
PASSWORD=YOUR_PASSWORD # 🔒 Shoonya login password

# 🔴🤖 === Shoonya API (REQUIRED) ===
TOKEN=YOUR_TOTP_KEY # 🔒 TOTP secret
VC=YOUR_VENDOR_CODE # 🔒 Vendor code
APP_KEY=YOUR_APP_KEY # 🔒 API app key
IMEI=your_device_imei # 🔒 device id 

# 🔴 === Webhook auth (REQUIRED) ===
WEBHOOK_SECRET_KEY=your_webhook_secret # 🔒 shared webhook secret

# 🤖 === Telegram (OPTIONAL for alerts) ===
TELEGRAM_TOKEN=your_telegram_bot_token # 🔒 bot token
TELEGRAM_CHAT_ID=your_chat_id # numeric chat id
TELEGRAM_ALLOWED_USERS=comma_separated_user_ids # comma-separated user ids

# 🔴 === Dashboard login (REQUIRED) ===
DASHBOARD_PASSWORD=change_me # 🔒 dashboard login password

# ============================================================
# ⚙️ === SERVER PORTS (REQUIRED FOR MULTI-CLIENT) ===
# Each client running on the same host MUST use unique ports.
# Recommended scheme:
#   Client 1: PORT=5001  DASHBOARD_PORT=8001
#   Client 2: PORT=5002  DASHBOARD_PORT=8002
#   Client 3: PORT=5003  DASHBOARD_PORT=8003
# ============================================================
HOST=0.0.0.0                      # bind address
PORT=5001                         # 🔴 UNIQUE execution/webhook port per client
DASHBOARD_PORT=8001               # 🔴 UNIQUE dashboard port per client
THREADS=4                         # waitress threads

# ⚙️ === GATEWAY ROUTING ===
CLIENT_ID_ALIAS=YOUR_USER_ID      # URL-safe alias for gateway routing (e.g. FA14667)

# ⚙️ === Database (OPTIONAL — for multi-client isolation) ===
# ORDERS_DB_PATH=shoonya_platform/persistence/data/orders_YOUR_USER_ID.db

# ⚙️ === Retry / report (OPTIONAL tuning) ===
MAX_RETRY_ATTEMPTS=3 # retry attempts for transient errors
RETRY_DELAY=1 # seconds between retries
REPORT_FREQUENCY_MINUTES=10 # report interval in minutes

# ⚠️ === Risk management (REQUIRED) ===
RISK_BASE_MAX_LOSS=-15000 # ⚠️ MUST be negative (absolute daily loss limit ₹)
RISK_TRAIL_STEP=1000 # trail step size ₹

# ✅ === Risk fine-tuning (OPTIONAL defaults) ===
RISK_WARNING_THRESHOLD=0.80 # warning threshold (0-1)
RISK_MAX_CONSECUTIVE_LOSS_DAYS=3 # max consecutive loss days
RISK_STATUS_UPDATE_MIN=30 # status update interval minutes
RISK_STATE_FILE=./logs/YOUR_USER_ID/risk_state.json # per-client risk state file
RISK_PNL_RETENTION_1M=3 # retention days for 1m pnl
RISK_PNL_RETENTION_5M=7 # retention days for 5m pnl
RISK_PNL_RETENTION_1D=30 # retention days for 1d pnl

# ============================================================
# 🔁 === COPY TRADING SETTINGS ===
# ============================================================
COPY_TRADING_ROLE=standalone      # standalone | master | follower
COPY_TRADING_SECRET=change_me_copy_secret  # 🔒 Shared HMAC secret
# COPY_TRADING_FOLLOWERS=http://127.0.0.1:5002,http://127.0.0.1:5003  # master only
# COPY_TRADING_MASTER_ENDPOINT=http://127.0.0.1:5001                   # follower only
COPY_TRADING_MODE=mirror          # mirror | scaled
# COPY_TRADING_SCALE_FACTOR=1.0

# ============================================================
# 🛡️ === MASTER MANAGER SETTINGS (OPTIONAL) ===
# ============================================================
# MASTER_MANAGER_URL=http://127.0.0.1:9000
# MASTER_MANAGER_TOKEN=your_master_token
