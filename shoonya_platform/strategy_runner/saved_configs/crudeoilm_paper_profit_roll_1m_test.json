    "check_interval_min": 0,
    "max_adjustments_per_day": 1,
    "cooldown_seconds": 10,
    "rules": [
      {
        "priority": 1,
        "name": "Roll CE if CE is most profitable after 60s",
        "rule_type": "if_then",
        "conditions": {
          "operator": "AND",
          "rules": [
            {
              "parameter": "time_in_position_sec",
              "comparator": ">=",
              "value": 60
            },
            {
              "parameter": "adjustments_today",
              "comparator": "==",
              "value": 0
            },
            {
              "parameter": "most_profitable_leg",
              "comparator": "==",
              "value": "CE"
            }
          ]
        },
        "action": {
          "type": "roll_ce"
        }
      },
      {
        "priority": 2,
        "name": "Roll PE if PE is most profitable after 60s",
        "rule_type": "if_then",
        "conditions": {
          "operator": "AND",
          "rules": [
            {
              "parameter": "time_in_position_sec",
              "comparator": ">=",
              "value": 60
            },
            {
              "parameter": "adjustments_today",
              "comparator": "==",
              "value": 0
            },
            {
              "parameter": "most_profitable_leg",
              "comparator": "==",
              "value": "PE"
            }
          ]
        },
        "action": {
          "type": "roll_pe"
        }
      }
    ]
  },
  "exit": {
    "rule_type": "if_any",
    "conditions": [
      {
        "parameter": "time_in_position_sec",
        "comparator": ">=",
        "value": 120
