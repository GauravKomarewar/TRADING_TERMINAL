{
  "schema_version": "3.0",
  "name": "CRUDEOILM_PAPER_MULTISTAGE_ADJUST_5M_TEST",
  "description": "Paper test: 5m lifecycle with 1m staged adjustments (profit, delta, greek/price, both-leg) then exit all",
  "paper_mode": false,
  "run_once": true,
  "poll_interval_sec": 2,
  "basic": {
    "exchange": "MCX",
    "underlying": "CRUDEOILM",
    "expiry_mode": "weekly_current",
    "lots": 1,
    "enabled": true
  },
  "timing": {
    "entry_time": "09:00",
    "exit_time": "23:30"
  },
  "market_data": {
    "source": "database"
  },
  "entry": {
    "rule_type": "always",
    "conditions": {
      "operator": "AND",
      "rules": [
        {
          "parameter": "ce_delta",
          "comparator": "~=",
          "value": 0.4,
          "tolerance": 0.1
        },
        {
          "parameter": "pe_delta",
          "comparator": "~=",
          "value": 0.4,
          "tolerance": 0.1
        }
      ]
    },
    "action": {
      "type": "short_strangle"
    }
  },
  "adjustment": {
    "enabled": true,
    "check_interval_min": 0,
    "max_adjustments_per_day": 4,
    "cooldown_seconds": 10,
    "rules": [
      {
        "priority": 1,
        "name": "Minute1 profit based: roll CE if CE most profitable",
        "rule_type": "if_then",
        "conditions": {
          "operator": "AND",
          "rules": [
            {
              "parameter": "time_in_position_sec",
              "comparator": ">=",
              "value": 60
            },
            {
              "parameter": "adjustments_today",
              "comparator": "==",
              "value": 0
            },
            {
              "parameter": "most_profitable_leg",
              "comparator": "==",
              "value": "CE"
            }
          ]
        },
        "action": {
          "type": "roll_ce"
        }
      },
      {
        "priority": 2,
        "name": "Minute1 profit based: roll PE if PE most profitable",
        "rule_type": "if_then",
        "conditions": {
          "operator": "AND",
          "rules": [
            {
              "parameter": "time_in_position_sec",
              "comparator": ">=",
              "value": 60
            },
            {
              "parameter": "adjustments_today",
              "comparator": "==",
              "value": 0
            },
            {
              "parameter": "most_profitable_leg",
              "comparator": "==",
              "value": "PE"
            }
          ]
        },
        "action": {
          "type": "roll_pe"
        }
      },
      {
        "priority": 3,
        "name": "Minute2 delta based adjustment",
        "rule_type": "if_then",
        "conditions": {
          "operator": "AND",
          "rules": [
            {
              "parameter": "time_in_position_sec",
              "comparator": ">=",
              "value": 120
            },
            {
              "parameter": "adjustments_today",
              "comparator": "==",
              "value": 1
            },
            {
              "parameter": "delta_diff",
              "comparator": ">=",
              "value": 0.0
            }
          ]
        },
        "action": {
          "type": "shift_strikes"
        }
      },
      {
        "priority": 4,
        "name": "Minute3 greek/price based adjustment",
        "rule_type": "if_then",
        "conditions": {
          "operator": "AND",
          "rules": [
            {
              "parameter": "time_in_position_sec",
              "comparator": ">=",
              "value": 180
            },
            {
              "parameter": "adjustments_today",
              "comparator": "==",
              "value": 2
            },
            {
              "parameter": "any_leg_delta",
              "comparator": ">=",
              "value": 0.0
            }
          ]
        },
        "action": {
          "type": "shift_strikes"
        }
      },
      {
        "priority": 5,
        "name": "Minute4 both leg adjustment",
        "rule_type": "if_then",
        "conditions": {
          "operator": "AND",
          "rules": [
            {
              "parameter": "time_in_position_sec",
              "comparator": ">=",
              "value": 240
            },
            {
              "parameter": "adjustments_today",
              "comparator": "==",
              "value": 3
            }
          ]
        },
        "action": {
          "type": "roll_both"
        }
      }
    ]
  },
  "exit": {
    "rule_type": "if_any",
    "conditions": [
      {
        "parameter": "time_in_position_sec",
        "comparator": ">=",
        "value": 300
      },
      {
        "parameter": "time_current",
        "comparator": ">=",
        "value": "23:30"
      }
    ],
    "action": {
      "type": "close_all_positions"
    }
  },
  "risk_management": {
    "max_loss_per_day": 20000,
    "max_trades_per_day": 50,
    "position_sizing": {
      "max_lots": 1,
      "scale_enabled": false
    }
  },
