# ============================================================
# SHOONYA PLATFORM — MASTER MANAGER CONFIG
# ============================================================
# Copy to: config_env/master.env
# Run: python master_manager.py --env config_env/master.env
# ============================================================

# 🔴 === Master Manager Identity (REQUIRED) ===
MASTER_NAME=PLATFORM_OWNER         # Display name for the master manager
MASTER_ADMIN_PASSWORD=change_me    # 🔒 Admin dashboard login password (min 12 chars, no weak defaults)
MASTER_API_TOKEN=change_me_master_token  # 🔒 Bearer token for master control API (min 12 chars)

# ⚙️ === Server Ports (REQUIRED) ===
MASTER_HOST=127.0.0.1             # Bind address (use 0.0.0.0 only behind proxy/firewall)
MASTER_PORT=9000                  # Master control API port
MASTER_DASHBOARD_PORT=9001        # Master dashboard UI port

# ⚙️ === Client Registry ===
# JSON file storing all registered client accounts and their state.
MASTER_REGISTRY_FILE=./config_env/master_clients.json

# 🤖 === Telegram (OPTIONAL — for master-level alerts) ===
# MASTER_TELEGRAM_TOKEN=your_telegram_bot_token
# MASTER_TELEGRAM_CHAT_ID=your_chat_id

# ⚙️ === Master Manager Behaviour ===
# How often (seconds) the master polls registered clients for health
MASTER_HEALTH_POLL_INTERVAL=30

# Automatically block a client if it misses this many health checks
MASTER_AUTO_BLOCK_MISSED_POLLS=3
